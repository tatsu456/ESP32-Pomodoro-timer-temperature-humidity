// ==========================================
// 1. 各種設定
// ==========================================
// --- WiFi設定 ---
const char* ssid = "tatwifi";      // ★ご自身のWi-FiのSSID
const char* password = "oopp5963"; // ★ご自身のWi-Fiのパスワード

// --- ディスプレイ設定 (SH1107 128x128用) ---
#define I2C_ADDRESS 0x3c
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 128
#define OLED_RESET -1
Adafruit_SH1107 display = Adafruit_SH1107(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

// --- センサー・IR・ブザー設定 ---
#define IR_RECEIVE_PIN 13 // IRセンサーのピン
#define BUZZER_PIN 14     // ★追加：ブザーのプラス(+)を繋ぐピン

Adafruit_SHT31 sht31 = Adafruit_SHT31();
float currentTemp = 0.0;
float currentHumid = 0.0;
unsigned long lastSensorRead = 0;

// --- 天気予報データ保存用 ---
String forecastDate[3] = {"-", "-", "-"};
int forecastCode[3] = {-1, -1, -1};
float forecastTempMax[3] = {0, 0, 0};
float forecastTempMin[3] = {0, 0, 0};
unsigned long lastWeatherUpdate = 0;

// --- リモコンの HEXコード ---
#define IR_BTN_SWITCH     0xED127F80
#define IR_BTN_W15        0xFB047F80
#define IR_BTN_W20        0xFA057F80
#define IR_BTN_W25        0xF9067F80
#define IR_BTN_W30        0xF8077F80
#define IR_BTN_W35        0xF7087F80
#define IR_BTN_W40        0xF6097F80
#define IR_BTN_W45        0xF50A7F80
#define IR_BTN_B5         0xFE017F80
#define IR_BTN_B10        0xFD027F80
#define IR_BTN_START_STOP 0xE51A7F80
#define IR_BTN_RESET      0xE11E7F80

// ==========================================
// 2. 状態管理変数
// ==========================================
enum DisplayMode { DISP_TIMER, DISP_ENV };
DisplayMode currentDisplayMode = DISP_TIMER;

enum TimerState { IDLE, WORK, BREAK, ANIM_TO_WORK, ANIM_TO_BREAK };
TimerState currentState = IDLE;

// 時間を「秒数」で管理
unsigned long workDurationSecs = 25 * 60;
unsigned long breakDurationSecs = 5 * 60;
long remainingSecs = workDurationSecs;
int completedCycles = 0; 

unsigned long lastTickMillis = 0;
unsigned long animStartMillis = 0;
const unsigned long ANIM_DURATION = 5000;

bool displayNeedsUpdate = true;        
unsigned long lastDrawMillis = 0;      
unsigned long lastIrReceiveMillis = 0; 

// --- 関数プロトタイプ宣言 ---
void updateSensor(unsigned long currentMillis);
void handleIR();
void toggleTimer();
void resetTimer();
void updateDurationSettings(int w_sec, int b_sec);
void updateTimer(unsigned long currentMillis);
void drawDisplay(unsigned long currentMillis);
void fetchWeather();
void drawWeatherIcon(int cx, int cy, int code);

// Webサーバー (ポート80)
WebServer server(80);

// ==========================================
// 3. Webサーバー用 HTML (UI画面)
// ==========================================
