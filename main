// ==========================================
// 4. Setup
// ==========================================
void setup() {
  Serial.begin(115200);

  // ★ブザー初期化
  pinMode(BUZZER_PIN, OUTPUT);
  digitalWrite(BUZZER_PIN, LOW); // 最初は音を止めておく

  // IR初期化
  IrReceiver.begin(IR_RECEIVE_PIN, ENABLE_LED_FEEDBACK);
  
  // 温湿度センサー初期化
  if (!sht31.begin(0x44)) {
    Serial.println("SHT31 Not Found!");
  }

  // OLED初期化
  if (!display.begin(I2C_ADDRESS, true)) {
    Serial.println("SH1107 allocation failed");
    for (;;);
  }
  
  // OLEDの描画速度を上げるためにI2C通信を高速化
  Wire.setClock(400000); 

  display.clearDisplay();
  display.setTextColor(SH110X_WHITE);
  display.setTextSize(1);
  display.setCursor(5, 50);
  display.print("Connecting WiFi...");
  display.display();

  // WiFi接続
  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, password);
  int retry = 0;
  while (WiFi.status() != WL_CONNECTED && retry < 20) {
    delay(500);
    Serial.print(".");
    retry++;
  }
  
  // 接続結果をOLEDに表示
  display.clearDisplay();
  display.setCursor(5, 40);
  if (WiFi.status() == WL_CONNECTED) {
    display.print("WiFi Connected!");
    display.setCursor(5, 60);
    display.print("IP: ");
    display.print(WiFi.localIP().toString());
  } else {
    display.print("WiFi Failed.");
    display.setCursor(5, 60);
    display.print("Offline Mode");
  }
  display.display();
  delay(3000);

  // 起動時に天気を取得
  if (WiFi.status() == WL_CONNECTED) {
    fetchWeather();
    lastWeatherUpdate = millis();
  }

  // Web APIルーティング設定
  server.on("/", HTTP_GET, []() {
    server.send(200, "text/html", html_page);
  });

  server.on("/api/status", HTTP_GET, []() {
    StaticJsonDocument<200> doc;
    char timeStr[6];
    sprintf(timeStr, "%02d:%02d", (int)(remainingSecs / 60), (int)(remainingSecs % 60));
    doc["timeStr"] = timeStr;
    doc["state"] = currentState;
    doc["setW"] = workDurationSecs;
    doc["setB"] = breakDurationSecs;
    doc["temp"] = currentTemp;
    doc["humid"] = currentHumid;
    doc["cycles"] = completedCycles; 
    
    String response;
    serializeJson(doc, response);
    server.send(200, "application/json", response);
  });

  server.on("/api/cmd", HTTP_GET, []() {
    if (server.hasArg("action")) {
      String action = server.arg("action");
      if (action == "toggle") toggleTimer();
      else if (action == "reset") resetTimer();
      else if (action == "disp_timer") currentDisplayMode = DISP_TIMER;
      else if (action == "disp_env") currentDisplayMode = DISP_ENV;
      
      displayNeedsUpdate = true; // Web操作時に画面更新
    }
    server.send(200, "text/plain", "OK");
  });

  server.on("/api/set", HTTP_GET, []() {
    if (server.hasArg("w") && server.hasArg("b")) {
      int w = server.arg("w").toInt(); // 秒単位で受け取る
      int b = server.arg("b").toInt(); // 秒単位で受け取る
      updateDurationSettings(w, b); 
      displayNeedsUpdate = true; // Web操作時に画面更新
    }
    server.send(200, "text/plain", "OK");
  });

  server.begin();
}

// ==========================================
// 5. Main Loop
// ==========================================
void loop() {
  unsigned long currentMillis = millis();

  server.handleClient();       // Webリクエスト処理 (非ブロッキング)
  handleIR();                  // リモコン処理 (非ブロッキング)
  updateSensor(currentMillis); // センサー読み取り
  updateTimer(currentMillis);  // タイマー進行処理
  
  // 1時間(3600000ms)ごとに天気予報を更新
  if (currentMillis - lastWeatherUpdate >= 3600000) {
    if (WiFi.status() == WL_CONNECTED) {
      fetchWeather();
      lastWeatherUpdate = currentMillis;
      displayNeedsUpdate = true;
    }
  }

  if (currentState == ANIM_TO_WORK || currentState == ANIM_TO_BREAK) {
    // アニメーション中は約30fps(33ms間隔)で描画し、スムーズさを保ちつつ余力を残す
    if (currentMillis - lastDrawMillis >= 33) {
      drawDisplay(currentMillis);
      lastDrawMillis = currentMillis;
    }
  } else {
    // 通常時（タイマーや温度画面）は、「内容が変わった時」だけ描画する
    if (displayNeedsUpdate) {
      drawDisplay(currentMillis);
      displayNeedsUpdate = false; // 描画完了したらフラグを戻す
    }
  }
}


// ==========================================
// 6. 各種処理ロジック
// ==========================================
void updateSensor(unsigned long currentMillis) {
  // 2秒に1回読み取る
  if (currentMillis - lastSensorRead > 2000) {
    lastSensorRead = currentMillis;
    currentTemp = sht31.readTemperature();
    currentHumid = sht31.readHumidity();
    displayNeedsUpdate = true; // 値が変わったので画面更新フラグを立てる
  }
}

// 埼玉県宮代町の天気を取得 (Open-Meteo API / APIキー不要)
void fetchWeather() {
  HTTPClient http;
  String url = "http://api.open-meteo.com/v1/forecast?latitude=36.024&longitude=139.715&daily=weather_code,temperature_2m_max,temperature_2m_min&timezone=Asia%2FTokyo&forecast_days=3";
  http.begin(url);
  int httpCode = http.GET();
  
  if (httpCode == HTTP_CODE_OK) {
    String payload = http.getString();
    DynamicJsonDocument doc(2048);
    DeserializationError error = deserializeJson(doc, payload);
    
    if (!error) {
      for (int i = 0; i < 3; i++) {
        String dateStr = doc["daily"]["time"][i].as<String>();
        if(dateStr.length() >= 10) {
          forecastDate[i] = dateStr.substring(5, 7) + "/" + dateStr.substring(8, 10);
        }
        forecastCode[i] = doc["daily"]["weather_code"][i].as<int>();
        forecastTempMax[i] = doc["daily"]["temperature_2m_max"][i].as<float>();
        forecastTempMin[i] = doc["daily"]["temperature_2m_min"][i].as<float>();
      }
    }
  }
  http.end();
}

void handleIR() {
  if (IrReceiver.decode()) {
    uint32_t irCode = IrReceiver.decodedIRData.decodedRawData;
    
    // リピートコード(0)を無視し、前回の受信から「150ms以上」経過している場合のみ処理
    if (irCode != 0 && (millis() - lastIrReceiveMillis > 150)) {
      lastIrReceiveMillis = millis();

      // ★追加：リモコンのボタンが押されたら「ピッ」と短く鳴らす
      digitalWrite(BUZZER_PIN, HIGH);
      delay(30);
      digitalWrite(BUZZER_PIN, LOW);
      
      switch (irCode) {
        case IR_BTN_SWITCH: 
          currentDisplayMode = (currentDisplayMode == DISP_TIMER) ? DISP_ENV : DISP_TIMER; 
          break;
        
        // ★修正：リモコンで時間を指定した際、即座にリセットしてその時間に合わせる
        case IR_BTN_W15: workDurationSecs = 15 * 60; resetTimer(); break;
        case IR_BTN_W20: workDurationSecs = 20 * 60; resetTimer(); break;
        case IR_BTN_W25: workDurationSecs = 25 * 60; resetTimer(); break;
        case IR_BTN_W30: workDurationSecs = 30 * 60; resetTimer(); break;
        case IR_BTN_W35: workDurationSecs = 35 * 60; resetTimer(); break;
        case IR_BTN_W40: workDurationSecs = 40 * 60; resetTimer(); break;
        case IR_BTN_W45: workDurationSecs = 45 * 60; resetTimer(); break;
        
        case IR_BTN_B5:  breakDurationSecs = 5 * 60;  resetTimer(); break;
        case IR_BTN_B10: breakDurationSecs = 10 * 60; resetTimer(); break;

        case IR_BTN_START_STOP: toggleTimer(); break;
        case IR_BTN_RESET:      resetTimer(); break;
      }
      displayNeedsUpdate = true; // リモコンで操作したら画面更新フラグを立てる
    }
    IrReceiver.resume();
  }
}

void updateDurationSettings(int w_sec, int b_sec) {
  if (w_sec > 0) workDurationSecs = w_sec;
  if (b_sec > 0) breakDurationSecs = b_sec;

  if (currentState == WORK || currentState == IDLE) { 
    if (remainingSecs > workDurationSecs) {
      remainingSecs = workDurationSecs;
    }
  } else if (currentState == BREAK) {
    if (remainingSecs > breakDurationSecs) {
      remainingSecs = breakDurationSecs;
    }
  }
}

void toggleTimer() {
  if (currentState == IDLE) {
    currentState = WORK;
    lastTickMillis = millis();
  } else if (currentState == WORK || currentState == BREAK) {
    currentState = IDLE; 
  }
}

void resetTimer() {
  currentState = IDLE;
  remainingSecs = workDurationSecs;
  completedCycles = 0; 
  currentDisplayMode = DISP_TIMER;
}

void updateTimer(unsigned long currentMillis) {
  if (currentState == WORK || currentState == BREAK) {
    if (currentMillis - lastTickMillis >= 1000) {
      lastTickMillis = currentMillis; 
      if (remainingSecs > 0) {
        remainingSecs--;
      }
      displayNeedsUpdate = true; // 1秒経過（秒数が減った）ので画面更新フラグを立てる
      
      if (remainingSecs == 0) {
        if (currentState == WORK) {
          completedCycles++; 
          currentState = ANIM_TO_BREAK; 
          currentDisplayMode = DISP_TIMER;

          // ★修正：作業終了の音 (ピピピ、ピピピ、ピピピ)
          for (int j = 0; j < 3; j++) {
            for (int i = 0; i < 3; i++) {
              digitalWrite(BUZZER_PIN, HIGH);
              delay(50);
              digitalWrite(BUZZER_PIN, LOW);
              delay(50);
            }
            delay(200); // 3連符の間の休符
          }
        } else {
          currentState = ANIM_TO_WORK; 
          currentDisplayMode = DISP_TIMER;

          // ★修正：休憩終了の音 (ピー、ピー、ピー)
          for (int i = 0; i < 3; i++) {
            digitalWrite(BUZZER_PIN, HIGH);
            delay(400);
            digitalWrite(BUZZER_PIN, LOW);
            delay(200);
          }
        }
        animStartMillis = millis(); // 音を鳴らした分のズレをリセット
      }
    }
  } 
  else if (currentState == ANIM_TO_BREAK || currentState == ANIM_TO_WORK) {
    if (currentMillis - animStartMillis >= ANIM_DURATION) {
      if (currentState == ANIM_TO_BREAK) {
        currentState = BREAK;
        remainingSecs = breakDurationSecs;
      } else {
        currentState = WORK;
        remainingSecs = workDurationSecs;
      }
      lastTickMillis = currentMillis; 
      displayNeedsUpdate = true; // アニメーション終了後に画面更新
    }
  }
}

// ==========================================
// 7. 画面描画処理 (128x128 ピクセル SH1107用)
// ==========================================
void drawDisplay(unsigned long currentMillis) {
  display.clearDisplay();

  if (currentState == ANIM_TO_WORK || currentState == ANIM_TO_BREAK) {
    float t = (currentMillis - animStartMillis) / 1000.0;

    if (currentState == ANIM_TO_WORK) {
      // ＝＝＝ ロケット＆渦巻きアニメーション (休憩->作業) ＝＝＝
      float rocketY = 128.0 - (t / (ANIM_DURATION / 1000.0)) * 160.0; 
      
      float angleOffset = t * 15.0; 
      for (int arm = 0; arm < 3; arm++) {
        float armOffset = arm * (TWO_PI / 3.0);
        for (float r = 0; r < 90; r += 4.0) {
          float theta = r * 0.15 + angleOffset + armOffset;
          int x = 64 + r * cos(theta);
          int y = 64 + r * sin(theta);
          display.drawPixel(x, y, SH110X_WHITE);
        }
      }

      // ★修正：よりロケットらしいデザイン
      // 先端（ノーズコーン）
      display.fillTriangle(64, rocketY, 56, rocketY + 15, 72, rocketY + 15, SH110X_WHITE);
      // 胴体
      display.fillRect(56, rocketY + 15, 16, 25, SH110X_WHITE);
      // 窓
      display.fillCircle(64, rocketY + 22, 4, SH110X_BLACK);
      // 左翼
      display.fillTriangle(56, rocketY + 25, 48, rocketY + 40, 56, rocketY + 40, SH110X_WHITE);
      // 右翼
      display.fillTriangle(72, rocketY + 25, 80, rocketY + 40, 72, rocketY + 40, SH110X_WHITE);
      // 噴射の炎
      display.fillTriangle(58, rocketY + 40, 70, rocketY + 40, 64, rocketY + 55 + sin(t*30)*8, SH110X_WHITE);
      
      if ((currentMillis / 300) % 2 == 0) {
        display.fillRect(30, 54, 68, 20, SH110X_BLACK);
        display.setTextSize(2);
        display.setCursor(34, 57);
        display.print("WORK!");
      }

    } else if (currentState == ANIM_TO_BREAK) {
      // ＝＝＝ コーヒーブレイクアニメーション (作業->休憩) ＝＝＝
      int cupX = 44;
      int cupY = 64;
      int cupW = 40;
      int cupH = 28;
      
      // ★修正：よりコーヒーカップらしいデザイン
      // ソーサー（お皿）
      display.fillRoundRect(cupX - 8, cupY + cupH - 2, cupW + 16, 4, 2, SH110X_WHITE);
      
      // 取っ手
      display.drawCircle(cupX + cupW, cupY + cupH / 2 - 2, 8, SH110X_WHITE);
      display.drawCircle(cupX + cupW, cupY + cupH / 2 - 2, 7, SH110X_WHITE);
      
      // カップ本体 (下の方を少し丸く)
      display.fillRoundRect(cupX, cupY, cupW, cupH, 8, SH110X_WHITE);
      display.fillRect(cupX, cupY, cupW, cupH - 8, SH110X_WHITE);
      
      // 飲み口の立体感
      display.fillRoundRect(cupX + 2, cupY - 4, cupW - 4, 8, 4, SH110X_BLACK);
      display.drawRoundRect(cupX + 2, cupY - 4, cupW - 4, 8, 4, SH110X_WHITE);

      // リアルで太めの湯気
      for (int i = 0; i < 3; i++) {
        float phase = i * 2.0;
        float steamY = (cupY - 5) - fmod((t * 10.0 + i * 15.0), 40.0); 
        float steamX = cupX + 10 + (i * 10) + sin(t * 2.5 + phase) * 5.0;
        if (steamY > 15) {
          display.fillCircle((int)steamX, (int)steamY, 3, SH110X_WHITE);
          display.fillCircle((int)(steamX + sin(t * 2.5 + phase + 0.5) * 3), (int)steamY - 6, 2, SH110X_WHITE);
        }
      }

      if ((currentMillis / 400) % 2 == 0) {
        display.setTextSize(2);
        display.setCursor(35, 20);
        display.print("BREAK");
      }
    }
  } 
  else {
    if (currentDisplayMode == DISP_TIMER) {
      // ----------------------------------------
      // タイマー画面
      // ----------------------------------------
      
      // 状態テキストを「白背景＋黒文字＋右下の影」で強調表示
      String stateStr = "";
      if (currentState == IDLE) stateStr = " PAUSED ";
      else if (currentState == WORK) stateStr = " WORKING ";
      else if (currentState == BREAK) stateStr = " RELAXING ";

      display.setTextSize(2); // 文字サイズを2に拡大
      int16_t x1, y1;
      uint16_t w, h;
      display.getTextBounds(stateStr, 0, 0, &x1, &y1, &w, &h);
      
      int textX = (128 - w) / 2; // 中央揃え
      int textY = 4;

      // 白い影の枠を右下に描画
      display.drawRoundRect(textX + 2, textY + 2, w, h + 4, 3, SH110X_WHITE);
      // 白い背景を前面に描画
      display.fillRoundRect(textX, textY, w, h + 4, 3, SH110X_WHITE);
      // その上に黒文字でプリント
      display.setTextColor(SH110X_BLACK, SH110X_WHITE);
      display.setCursor(textX, textY + 2);
      display.print(stateStr);
      // 以降の文字のために色を白に戻す
      display.setTextColor(SH110X_WHITE, SH110X_BLACK);

      // 大きな残り時間
      int mins = remainingSecs / 60;
      int secs = remainingSecs % 60;
      
      display.setTextSize(3); 
      int xOffset = (mins < 10) ? 28 : 15; 
      display.setCursor(xOffset, 35);
      if (mins < 10) display.print("0");
      display.print(mins);
      display.print(":");
      if (secs < 10) display.print("0");
      display.print(secs);

      // プログレスバー
      float progress = 0.0;
      if (currentState == WORK || currentState == IDLE) {
        progress = (float)remainingSecs / workDurationSecs;
      } else {
        progress = (float)remainingSecs / breakDurationSecs;
      }
      display.drawRect(9, 75, 110, 12, SH110X_WHITE);
      display.fillRect(9, 75, 110 * progress, 12, SH110X_WHITE);

      // 設定値表示
      display.setTextSize(1);
      display.drawLine(0, 95, 128, 95, SH110X_WHITE);
      
      display.setCursor(5, 100);
      display.print("Set: W");
      display.print(workDurationSecs / 60);
      display.print(":");
      if((workDurationSecs % 60) < 10) display.print("0");
      display.print(workDurationSecs % 60);
      display.print(" B");
      display.print(breakDurationSecs / 60);
      display.print(":");
      if((breakDurationSecs % 60) < 10) display.print("0");
      display.print(breakDurationSecs % 60);

      display.setCursor(5, 112);
      display.print("Cycles: ");
      display.print(completedCycles);

    } else if (currentDisplayMode == DISP_ENV) {
      // ----------------------------------------
      // 環境・天気画面
      // ----------------------------------------
      display.setTextSize(1);
      display.setCursor(0, 0);
      display.print("Temp : ");
      display.print(currentTemp, 1);
      display.print(" C");

      display.setCursor(0, 12);
      display.print("Humid: ");
      display.print(currentHumid, 1);
      display.print(" %");

      display.drawLine(0, 24, 128, 24, SH110X_WHITE);

      for (int i = 0; i < 3; i++) {
        int y = 28 + i * 33;
        
        if (forecastCode[i] == -1) {
          display.setCursor(10, y + 10);
          display.print("Loading weather...");
          continue;
        }
        
        display.setCursor(0, y + 10);
        display.print(forecastDate[i]);
        
        drawWeatherIcon(55, y + 14, forecastCode[i]);
        
        display.setCursor(75, y + 10);
        display.print((int)forecastTempMax[i]);
        display.print("/");
        display.print((int)forecastTempMin[i]);
        display.print("C");
      }
    }
  }

  display.display();
}

void drawWeatherIcon(int cx, int cy, int code) {
  if (code == 0 || code == 1) { 
    display.fillCircle(cx, cy, 6, SH110X_WHITE);
  } else if (code == 2 || code == 3) { 
    display.fillRoundRect(cx-8, cy-4, 16, 10, 4, SH110X_WHITE);
  } else if (code >= 50 && code <= 69) { 
    display.drawRoundRect(cx-8, cy-6, 16, 8, 3, SH110X_WHITE);
    display.drawLine(cx-4, cy+3, cx-6, cy+8, SH110X_WHITE);
    display.drawLine(cx, cy+3, cx-2, cy+8, SH110X_WHITE);
    display.drawLine(cx+4, cy+3, cx+2, cy+8, SH110X_WHITE);
  } else if (code >= 70 && code <= 79) { 
    display.drawLine(cx-6, cy-6, cx+6, cy+6, SH110X_WHITE);
    display.drawLine(cx-6, cy+6, cx+6, cy-6, SH110X_WHITE);
    display.drawLine(cx, cy-8, cx, cy+8, SH110X_WHITE);
    display.drawLine(cx-8, cy, cx+8, cy, SH110X_WHITE);
  } else { 
    display.drawLine(cx+2, cy-7, cx-4, cy+1, SH110X_WHITE);
    display.drawLine(cx-4, cy+1, cx+2, cy+1, SH110X_WHITE);
    display.drawLine(cx+2, cy+1, cx-4, cy+8, SH110X_WHITE);
  }
}
